{
  "name": "chat-window",
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "export": "next export",
    "deploy": "npm run build && npm run export",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "start": "next start -p 8080",
    "prepare": "husky install"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "antd": "^4.4.2",
    "dayjs": "^1.10.4",
    "framer-motion": "^4.1.14",
    "next": "^10.2.0",
    "phoenix": "^1.5.4",
    "rc-upload": "^4.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-markdown": "^6.0.2",
    "remark-breaks": "^2.0.0",
    "remark-emoji": "^2.2.0",
    "superagent": "^6.1.0",
    "theme-ui": "^0.8.4",
    "tinycolor2": "^1.4.1",
    "use-composed-ref": "^1.1.0",
    "use-latest": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^15.0.2",
    "@types/phoenix": "^1.5.0",
    "@types/react": "^17.0.5",
    "@types/superagent": "^4.1.8",
    "@types/tinycolor2": "^1.4.2",
    "husky": "^6.0.0",
    "lint-staged": "^11.0.0",
    "prettier": "^2.0.5",
    "typescript": "^4.2.4"
  }
}
